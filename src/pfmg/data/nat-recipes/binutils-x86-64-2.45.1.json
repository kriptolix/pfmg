{
  "header": {
    "id": "binutils-x86-64",
    "version": "2.45.1",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "binutils-x86_64",
    "build-options": {
      "config-opts": [
        "--target=x86_64-w64-mingw32"
      ]
    },
    "config-opts": [
      "--with-system-zlib",
      "--enable-lto",
      "--enable-plugins",
      "--enable-deterministic-archives",
      "--disable-multilib",
      "--disable-nls",
      "--disable-werror"
    ],
    "install-rule": "install-strip",
    "builddir": true,
    "sources": [
      {
        "type": "archive",
        "url": "https://ftp.gnu.org/gnu/binutils/binutils-2.45.1.tar.gz",
        "sha256": "2b63ae0ad015eb2755294f127bfd179c1849979dd87b6e8e1a7376964a4323dc"
      }
    ]
  }
}
