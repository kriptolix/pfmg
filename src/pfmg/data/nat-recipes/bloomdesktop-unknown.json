{
  "header": {
    "id": "bloomdesktop",
    "version": "unknown",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "BloomDesktop",
    "buildsystem": "simple",
    "build-options": {
      "append-path": "/usr/lib/sdk/node16/bin",
      "env": {
        "MONO_PREFIX": "/app",
        "MONO_SILPKGDIR": "/app",
        "NUGET_SRC": "nuget_packages",
        "NUGET_DEST": "packages",
        "INSTALLATION_PREFIX": "/app",
        "RUNMODE": "PACKAGING",
        "XDG_CACHE_HOME": "/run/build/flatpak-node/cache",
        "BLOOMLIB": "/app/lib/bloom-desktop",
        "BLOOMSHARE": "/app/share/bloom-desktop",
        "PREFIX": "/app",
        "PERL5LIB": "/app/perl-modules/lib/perl5",
        "BUILD_CONFIG": "Release"
      }
    },
    "build-commands": [
      "set -xueo pipefail\nyarn config set yarn-offline-mirror ${FLATPAK_BUILDER_BUILDDIR}/flatpak-node/yarn-mirror\ncp local-extra/Makefile .\nexport NODE_OPTIONS=--max-old-space-size=1536\nif [ -f local-extra/build_number.env ]; then . local-extra/build_number.env; else export FULL_BUILD_NUMBER=5.5.1.0; fi\nmake -B build\nmake -B install\n"
    ],
    "cleanup": [
      "/include",
      "/lib/*/include",
      "*.a"
    ],
    "sources": [
      {
        "type": "git",
        "url": "https://github.com/BloomBooks/BloomDesktop.git",
        "commit": "aa3895ddcf588d6be39029f5ebb5a68d5d8cef4a"
      },
      "bloom-build-nuget-sources.yml",
      "bloom-sources-nuget.yml",
      {
        "type": "shell",
        "commands": [
          "set -xueo pipefail\nfor package in ${NUGET_SRC}/*.nupkg; do\n  mkdir -p \"${NUGET_DEST}/$(basename \"${package}\" .nupkg)\" &&\n    unzip \"${package}\" \\\n      -d \"${NUGET_DEST}/$(basename \"${package}\" .nupkg)\"\ndone\n# repair damaged nupkgs\nmv \"${NUGET_DEST}/MarkdownDeep.NET.1.5.0/lib/.NetFramework%203.5\" \"${NUGET_DEST}/MarkdownDeep.NET.1.5.0/lib/.NetFramework 3.5\"\nchmod 755 \"${NUGET_DEST}\"/sqlite-net-pcl.1.7.335/*.*\nchmod 755 \"${NUGET_DEST}\"/sqlite-net-pcl.1.7.335/lib/netstandard2.0/SQLite-net.*\nchmod 755 \"${NUGET_DEST}\"/L10NSharp.6.0.0/lib/net461/L10NSharp.*\n# copy artifacts from internal geckofx builds to where the nuget packages have been installed.\n# (we need some things the nuget package includes, but want to replace the actual assemblies and add debug info)\nrm \"${NUGET_DEST}\"/Geckofx60.64.Linux.60.0.51/lib/net40/Geckofx-*.dll.mdb\ncp --verbose --force /app/geckofx/Geckofx-Core.dll \"${NUGET_DEST}\"/Geckofx60.64.Linux.60.0.51/lib/net40/\ncp --verbose --force /app/geckofx/Geckofx-Core.dll.config \"${NUGET_DEST}\"/Geckofx60.64.Linux.60.0.51/lib/net40/\ncp --verbose --force /app/geckofx/Geckofx-Core.pdb \"${NUGET_DEST}\"/Geckofx60.64.Linux.60.0.51/lib/net40/\ncp --verbose --force /app/geckofx/Geckofx-Winforms.dll \"${NUGET_DEST}\"/Geckofx60.64.Linux.60.0.51/lib/net40/\ncp --verbose --force /app/geckofx/Geckofx-Winforms.dll.config \"${NUGET_DEST}\"/Geckofx60.64.Linux.60.0.51/lib/net40/\ncp --verbose --force /app/geckofx/Geckofx-Winforms.pdb \"${NUGET_DEST}\"/Geckofx60.64.Linux.60.0.51/lib/net40/\nrm -rf /app/geckofx\n"
        ]
      },
      "bloom-sources-urls.yml",
      {
        "type": "shell",
        "commands": [
          "set -xueo pipefail\npwd\nmkdir -p \"DistFiles/pdf\" && unzip -uqo Downloads/pdfjs-viewer.zip -d \"DistFiles/pdf\"\n"
        ]
      },
      "bloom-sources-browser-node.json",
      "bloom-sources-content-node.json",
      {
        "type": "patch",
        "path": "patches/BloomDesktop/BuildFileFixesForFlatpak.patch"
      },
      {
        "type": "patch",
        "path": "patches/BloomDesktop/CodeFixesForFlatpak.patch"
      },
      {
        "type": "dir",
        "path": "./extra",
        "dest": "local-extra"
      },
      {
        "type": "file",
        "url": "https://dist.nuget.org/win-x86-commandline/v6.2.1/nuget.exe",
        "sha256": "a79f342e739fdb3903a92218767e7813e04930dff463621b6d2be2d468b84e05",
        "dest": ".nuget"
      }
    ],
    "modules": [
      "shared-modules/python2.7/python-2.7.json",
