        "name": "mono5-sil-msbuild",
        "buildsystem": "simple",
        "build-commands": [
          "for package in *.deb; do\n  mkdir \"${package}-dir\" &&\n    (cd \"${package}-dir\" && ar x ../\"${package}\") &&\n    tar -C /app -x -f \"${package}-dir\"/data.tar.xz \\\n      --strip-components=3 ./opt/mono5-sil\ndone\n",
          "perl -pi -e 's#/opt/mono5-sil#/./././././app#g' /app/bin/*"
