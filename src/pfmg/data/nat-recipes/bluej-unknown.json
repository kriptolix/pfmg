  "module": {
    "name": "bluej",
    "buildsystem": "simple",
    "build-commands": [
      "for size in 32 48 256; do install -Dm644 ./bluej/lib/images/bluej-icon-${size}.png /app/share/icons/hicolor/${size}x${size}/apps/org.bluej.BlueJ.png; done",
      "sed -Ei 's,https\\\\://services.gradle.org/distributions/,file:/run/build/bluej/,' gradle/wrapper/gradle-wrapper.properties",
      "./gradlew --no-daemon --offline :bluej:packageBluePreDist",
      "mkdir -p /app/bluej",
      "bsdunzip -o -d /app/bluej ./bluej/package/bluej-dist.jar"
    ],
