{
  "header": {
    "id": "cyrus-sasl2",
    "version": "2.1.28",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "cyrus-sasl2",
    "config-opts": [
      "--with-dblib=berkeley",
      "--without-pam",
      "--without-opie",
      "--without-des",
      "--disable-gssapi",
      "--enable-cram",
      "--enable-digest",
      "--enable-otp",
      "--enable-plain",
      "--enable-login",
      "--with-plugindir=/app/lib/sasl2"
    ],
    "build-options": {
      "cflags": "-Wno-implicit-function-declaration -Wno-incompatible-pointer-types"
    },
    "no-parallel-make": true,
    "sources": [
      {
        "type": "archive",
        "url": "https://github.com/cyrusimap/cyrus-sasl/archive/cyrus-sasl-2.1.28.tar.gz",
        "sha256": "3e38933a30b9ce183a5488b4f6a5937a702549cde0d3287903d80968ad4ec341",
        "x-checker-data": {
          "type": "anitya",
          "project-id": 13280,
          "stable-only": true,
          "url-template": "https://github.com/cyrusimap/cyrus-sasl/archive/cyrus-sasl-$version.tar.gz"
        }
      },
      {
        "type": "patch",
        "path": "patches/cyrus-sasl/1.patch"
      },
      {
        "type": "shell",
        "commands": [
          "cp -p /usr/share/automake-*/config.{sub,guess} ."
        ]
      }
    ]
  }
}
