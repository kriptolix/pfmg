      },
      {
        "dest-filename": "doclayout.cabal",
        "sha256": "36c81aa3849049588d46c3fb51cf23177e8cc08efab4bf0d0ed2fb0df764cc0e",
        "type": "file",
        "url": "https://hackage.haskell.org/package/doclayout-0.5/revision/0.cabal"
      }
    ]
  }
}
