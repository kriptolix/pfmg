      "mkdir -p \"${FLATPAK_DEST}/grayjay/cef\"",
      "mv native/build/Release/* \"${FLATPAK_DEST}/grayjay/cef\"",
      "chmod +x \"${FLATPAK_DEST}/grayjay/cef/dotcefnative\""
    ],
