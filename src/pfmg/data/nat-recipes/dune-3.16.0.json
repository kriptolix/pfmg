{
  "header": {
    "id": "dune",
    "version": "3.16.0",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "dune",
    "buildsystem": "simple",
    "sources": [
      {
        "type": "archive",
        "url": "https://github.com/ocaml/dune/archive/refs/tags/3.16.0.tar.gz",
        "sha256": "cf141fe2113d95faab9714bc3203f4665ba58c7e0c4450f9a719f1ba075cd214"
      },
      {
        "type": "patch",
        "path": "ocaml-dune-no-lwt.patch"
      }
    ],
    "build-commands": [
      "rm -fr otherlibs/dune-rpc-lwt dune-rpc-lwt.opam",
      "./configure --bindir=${FLATPAK_DEST}/bin --sbindir=${FLATPAK_DEST}/bin --libdir=${FLATPAK_DEST}/lib/ocaml --docdir=${FLATPAK_DEST}/share/doc --mandir=${FLATPAK_DEST}/share/man --datadir=${FLATPAK_DEST}/share/data --etcdir=${FLATPAK_DEST}/etc",
      "make release",
      "./dune.exe build --verbose --release @install",
      "PREFIX=${FLATPAK_DEST} make install",
      "./dune.exe install"
    ]
  }
}
