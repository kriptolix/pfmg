{
  "header": {
    "id": "eos-sdk",
    "version": "3.3.20",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "eos-sdk",
    "build-options": {
      "env": {
        "PYTHON": "python3"
      },
      "config-opts": [
        "--disable-gtk-doc",
        "--disable-gir-doc",
        "--disable-js-doc",
        "--disable-metrics",
        "--disable-webhelper"
      ]
    },
    "cleanup": [
      "/bin",
      "/libexec",
      "/share/gjs-1.0"
    ],
    "sources": [
      {
        "type": "archive",
        "url": "https://github.com/endlessm/eos-sdk/archive/refs/tags/Release_3.3.20.tar.gz",
        "sha256": "a78a585656395b375bee09d9b328f2a07312aad87ad9a15dd0e992d426a1edff"
      }
    ]
  }
}
