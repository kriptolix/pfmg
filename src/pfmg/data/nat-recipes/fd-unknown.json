{
  "header": {
    "id": "fd",
    "version": "unknown",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "fd",
    "sources": [
      "fd-cargo-sources.yml",
      {
        "type": "git",
        "url": "https://github.com/sharkdp/fd",
        "tag": "v10.4.2",
        "commit": "7027d45303b412be6fa9c09d689cc6276748fb38",
        "x-checker-data": {
          "type": "git"
        }
      }
    ],
    "build-options": {
      "append-path": "/usr/lib/sdk/rust-stable/bin",
      "env": {
        "CARGO_HOME": "/run/build/fd/cargo"
      }
