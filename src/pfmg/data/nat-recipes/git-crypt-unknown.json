{
  "header": {
    "id": "git-crypt",
    "version": "unknown",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "git-crypt",
    "buildsystem": "simple",
    "build-options": {
      "env": {
        "CXXFLAGS": "-DOPENSSL_API_COMPAT=0x30000000L",
        "PREFIX": "${FLATPAK_DEST}"
      }
    },
    "build-commands": [
      "make",
      "make install"
    ],
    "sources": [
      {
        "type": "git",
        "url": "https://github.com/AGWA/git-crypt",
        "tag": "0.8.0",
        "x-checker-data": {
          "type": "git",
          "tag-pattern": "^(\\d+.\\d+.\\d+)$"
        },
        "commit": "160cf642e1c0f83c1668ad0d59e879d97b97a95b"
      }
    ]
  }
}
