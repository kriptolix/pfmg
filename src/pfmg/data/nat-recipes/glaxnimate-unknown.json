    "version": "unknown",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "glaxnimate",
    "buildsystem": "cmake-ninja",
    "builddir": true,
    "config-opts": [
      "-DCMAKE_BUILD_TYPE=RelWithDebInfo",
      "-DPotrace_PREFIX=/app",
