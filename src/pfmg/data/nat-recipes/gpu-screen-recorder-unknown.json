{
  "header": {
    "id": "gpu-screen-recorder",
    "version": "unknown",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "gpu-screen-recorder",
    "disabled": false,
    "buildsystem": "simple",
    "build-commands": [
      "meson setup build",
      "meson configure --prefix=$FLATPAK_DEST --buildtype=release -Dcapabilities=false -Dsystemd=false -Dnvidia_suspend_fix=false -Dstrip=true build",
      "ninja -C build install",
      "gcc kms/server/kms_server.c -o gsr-kms-server $FLATPAK_DEST/lib/libdrm.a -I$FLATPAK_DEST/include/libdrm $GSR_KMS_SERVER_OPTS",
      "install -Dm755 gsr-kms-server \"$FLATPAK_DEST/bin/gsr-kms-server\"",
      "strip \"$FLATPAK_DEST/bin/gsr-kms-server\"",
      "strip \"$FLATPAK_DEST/bin/gpu-screen-recorder\""
    ],
    "build-options": {
      "env": {
        "GSR_KMS_SERVER_OPTS": "-fstack-protector-all -O3 -s -flto -Wall -Wextra -Werror -DNDEBUG -static -static-libgcc"
      }
    },
    "sources": [
      {
        "type": "archive",
        "url": "https://dec05eba.com/snapshot/gpu-screen-recorder.git.r1337.b6b9b32.tar.gz",
        "sha512": "bbabdd54d3407eb2cfe60c0042a9c6576e1dfabde7da8d90d15ff63f3629907e1f63437c254ab92b108e984cfbaa8c01c80c922064621e12d2d6fdb748f71792",
        "strip-components": 0
      }
    ],
    "modules": [
      {
        "name": "libdrm",
        "buildsystem": "meson",
        "config-opts": [
          "-Dintel=disabled",
          "-Dradeon=disabled",
          "-Damdgpu=disabled",
          "-Dnouveau=disabled",
          "-Dvmwgfx=disabled",
          "-Domap=disabled",
          "-Dexynos=disabled",
          "-Dfreedreno=disabled",
          "-Dtegra=disabled",
          "-Dvc4=disabled",
          "-Detnaviv=disabled",
          "-Dcairo-tests=disabled",
          "-Dman-pages=disabled",
          "-Dvalgrind=disabled",
          "-Dtests=false",
          "--default-library=static",
          "--buildtype=release"
        ],
        "sources": [
          {
            "type": "git",
            "url": "https://gitlab.freedesktop.org/mesa/drm.git",
            "commit": "ad78bb591d02162d3b90890aa4d0a238b2a37cde",
            "tag": "libdrm-2.4.122"
          }
        ]
      }
    ]
  }
}
