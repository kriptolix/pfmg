        "size": 78678630
      },
      {
        "type": "file",
        "path": "apply_extra.sh"
      },
      {
        "type": "file",
        "path": "guilded.sh"
      },
      {
        "type": "file",
        "path": "gg.guilded.Guilded.appdata.xml"
      },
      {
        "type": "file",
        "path": "guilded.png"
      },
      {
        "type": "file",
        "path": "gg.guilded.Guilded.desktop"
      }
    ]
  }
