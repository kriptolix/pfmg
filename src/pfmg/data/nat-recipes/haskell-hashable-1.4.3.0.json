{
  "header": {
    "id": "haskell-hashable",
    "version": "1.4.3.0",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "haskell-hashable",
    "buildsystem": "simple",
    "sources": [
      {
        "type": "archive",
        "url": "https://hackage.haskell.org/package/hashable-1.4.3.0/hashable-1.4.3.0.tar.gz",
