{
  "header": {
    "id": "javacheck",
    "version": "1.0.0",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "javacheck",
    "buildsystem": "cmake",
    "builddir": true,
    "config-opts": [
      "-DCMAKE_BUILD_TYPE=RelWithDebInfo"
    ],
    "build-options": {
      "env": {
        "JAVA_HOME": "/usr/lib/sdk/openjdk17/jvm/openjdk-17",
        "JAVA_COMPILER": "/usr/lib/sdk/openjdk17/jvm/openjdk-17/bin/javac"
      }
    },
    "sources": [
      {
        "type": "archive",
        "url": "https://ftp.projecttick.org/Project-Tick/javacheck/releases/download/javacheck-v1.0.0/javacheck-javacheck-v1.0.0.tar.gz",
        "sha256": "17267bed1589fc67f46d59231cbf6a1456fb1ede78a026ae1fd233740c34fa99",
        "x-checker-data": {
          "type": "json",
          "url": "https://ftp.projecttick.org/Project-Tick/latest.json",
          "version-query": ".products.javacheck.stable.release_tag",
          "url-query": ".products.javacheck.stable.files[] | select(.name == \"javacheck-\" + $version + \".tar.gz\") | .url"
        }
      }
    ]
  }
}
