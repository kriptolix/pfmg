        "type": "archive",
        "url": "https://download.kde.org/stable/release-service/25.12.2/src/kldap-25.12.2.tar.xz",
        "sha256": "ca13d0ec9e1cb4d19d654b9f55251ff5b36fcc649cab3add8c46cce1787fa80a",
        "x-checker-data": {
          "type": "anitya",
          "project-id": 8763,
