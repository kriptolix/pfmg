    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "kldap",
    "buildsystem": "cmake-ninja",
    "config-opts": [
      "-DBUILD_TESTING=OFF",
      "-DCMAKE_BUILD_TYPE=RelWithDebInfo"
    ],
    "sources": [
