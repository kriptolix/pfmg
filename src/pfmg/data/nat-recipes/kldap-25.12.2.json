              "version-pattern": "openldap-([\\d\\.-]+).tgz",
              "url-template": "https://www.openldap.org/software/download/OpenLDAP/openldap-release/openldap-$version.tgz"
            }
          }
        ],
        "cleanup": [
          "/bin/ldap*",
