{
  "header": {
    "id": "krb5-libs",
    "version": "1.20.1",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "krb5-libs",
    "buildsystem": "simple",
    "build-commands": [
      "set -e\nmkdir -p /app/lib\n\nfor deb in *.deb; do\n  echo \">>> Распаковываю $deb\"\n  tmpdir=\"$(mktemp -d)\"\n  (\n    cd \"$tmpdir\"\n\n    ar x \"$OLDPWD/$deb\"\n    bsdtar -xf data.tar.* -C \"$tmpdir\"\n\n    for dir in \\\n        \"$tmpdir/usr/lib\" \\\n        \"$tmpdir/usr/lib/x86_64-linux-gnu\" \\\n        \"$tmpdir/lib\" \\\n        \"$tmpdir/lib/x86_64-linux-gnu\"; do\n\n      if [ -d \"$dir\" ]; then\n        echo \">>> копирую из $dir\"\n        find \"$dir\" -name 'lib*.so*' -exec cp -av '{}' /app/lib/ \\; || true\n      fi\n    done\n  )\n  rm -rf \"$tmpdir\"\ndone\n"
    ],
