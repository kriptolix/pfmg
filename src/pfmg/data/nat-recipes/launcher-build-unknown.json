{
  "header": {
    "id": "launcher-build",
    "version": "unknown",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "launcher-build",
    "buildsystem": "simple",
    "build-options": {
      "append-path": "/usr/lib/sdk/rust-stable/bin",
      "env": {
        "CARGO_HOME": "/run/build/launcher-build/cargo",
        "CARGO_NET_OFFLINE": "true"
      }
    },
    "build-commands": [
      "cargo --offline fetch --manifest-path Cargo.toml --verbose",
      "cargo build --offline --release --all-features",
      "install -Dm0755 target/release/gsc-launcher /app/bin/launcher"
    ],
    "sources": [
      {
        "type": "git",
        "url": "https://github.com/parker-bryce-andrew/fracture-launcher.git",
        "commit": "1a86d4f45ac81b89cb3098dbd5460ed7f7efa49e"
      },
      "cargo-launcher-sources.json"
    ]
  }
}
