    "cleanup": [
      "/bin",
      "/share"
    ],
    "sources": [
      {
        "type": "archive",
        "url": "https://download.gnome.org/sources/libart_lgpl/2.3/libart_lgpl-2.3.21.tar.gz",
        "sha256": "2a10b1c884bb37c7bd5c5eba59dbd0d28bf68e64a42d7f2083c836f60f8e98fa"
      },
      {
        "type": "shell",
        "commands": [
          "rm -f config.guess"
        ]
      },
      {
        "type": "script",
        "commands": [
          "autoreconf -fiv"
        ],
        "dest-filename": "autogen.sh"
      }
    ]
  }
}
