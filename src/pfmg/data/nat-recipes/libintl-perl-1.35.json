{
  "header": {
    "id": "libintl-perl",
    "version": "1.35",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "libintl-perl",
    "buildsystem": "simple",
    "build-commands": [
      "perl Makefile.PL PREFIX=/app LIB=/app/lib",
      "make",
      "make install"
    ],
    "post-install": [
      "find ${FLATPAK_DEST}/lib/ -name \\*.so -exec chmod u+w {} \\;"
    ],
    "sources": [
      {
        "type": "archive",
        "url": "https://cpan.metacpan.org/authors/id/G/GU/GUIDO/libintl-perl-1.35.tar.gz",
        "sha256": "64abed956aa07d1c8cc816c91cf78642c02faf03ab704ed38031baa07f06b16a"
      }
    ]
  }
}
