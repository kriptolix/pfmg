{
  "header": {
    "id": "librsvg",
    "version": "2.62",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "librsvg",
    "buildsystem": "meson",
    "config-opts": [
      "-Drsvg-convert=disabled",
      "-Dvala=disabled",
      "-Ddocs=disabled",
      "-Dtests=false",
      "-Dpixbuf-loader=enabled",
      "-Dintrospection=enabled"
    ],
    "build-options": {
      "append-path": "/usr/lib/sdk/rust-stable/bin",
      "env": {
        "CARGO_HOME": "/run/build/librsvg/cargo"
      }
    },
    "sources": [
      "librsvg-cargo-sources.json",
      {
        "type": "archive",
        "url": "https://download.gnome.org/sources/librsvg/2.62/librsvg-2.62.1.tar.xz",
        "sha256": "b41ca84206242fddd826a2bf76348d7cdf52c1050cbfa060b866e81a252145c3",
        "x-checker-data": {
          "type": "gnome",
          "name": "librsvg",
          "stable-only": true
        }
      }
    ],
    "cleanup": [
      "/bin"
    ]
  }
}
