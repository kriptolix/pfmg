{
  "header": {
    "id": "libunwind",
    "version": "1.4.0",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "libunwind",
    "rm-configure": true,
    "build-options": {
      "prefix": "/usr/lib/sdk/dotnet"
    },
    "cleanup": [
