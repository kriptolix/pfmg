        "sha256": "2da62b57da70975d0865d4a1ae4ae4cf422e1b7dcc709eba855cf14f5104617e",
        "x-checker-data": {
          "type": "anitya",
          "project-id": 1887,
          "stable-only": true,
          "url-template": "https://archive.mariadb.org/mariadb-$version/source/mariadb-$version.tar.gz"
        }
      }
    ]
  }
}
