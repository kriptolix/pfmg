{
  "header": {
    "id": "mariadb-libs",
    "version": "12.3.1",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "mariadb-libs",
    "x-comment": "for mysql-boost",
    "config-opts": [
      "-DCOMPILATION_COMMENT=\"Flathub - QGIS\"",
      "-DCMAKE_BUILD_TYPE=Release",
      "-DFORCE_INSOURCE_BUILD=1",
      "-DWITH_EDITLINE=bundled",
      "-DWITH_PCRE2=system",
      "-DWITH_SSL=system",
      "-DWITH_ZLIB=system",
      "-DWITH_LIBFMT=system",
      "-DWITH_UNIT_TESTS=OFF",
      "-DPLUGIN_FEDERATED=NO",
      "-DWITHOUT_SERVER=ON"
