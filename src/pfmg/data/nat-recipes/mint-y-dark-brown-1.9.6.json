      "install -Dm644 usr/share/themes/Mint-Y-Dark-Brown/gtk-3.0/gtk.css /usr/share/runtime/share/themes/Mint-Y-Dark-Brown/gtk-3.0",
      "install -Dm644 --target-directory=/usr/share/runtime/share/themes/Mint-Y-Dark-Brown/gtk-3.0/assets usr/share/themes/Mint-Y-Dark-Brown/gtk-3.0/assets/*"
    ],
    "sources": [
