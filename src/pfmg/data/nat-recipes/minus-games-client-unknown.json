{
  "header": {
    "id": "minus-games-client",
    "version": "unknown",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "minus_games_client",
    "buildsystem": "simple",
    "build-options": {
      "append-path": "/usr/lib/sdk/rust-stable/bin",
      "env": {
        "CARGO_HOME": "/run/build/minus_games_client/cargo"
      }
    },
    "build-commands": [
      "cargo --offline fetch --manifest-path Cargo.toml",
      "cargo --offline build --release --bin minus_games_client",
      "install -Dm755 target/release/minus_games_client /app/bin/minus_games_client",
      "install -Dm644 other/assets/common/io.github.accessory.minus_games.svg /app/share/icons/hicolor/scalable/apps/io.github.accessory.minus_games_client.svg",
      "install -Dm644 other/assets/client/desktop/io.github.accessory.minus_games_client.desktop /app/share/applications/io.github.accessory.minus_games_client.desktop",
      "install -Dm644 other/assets/client/desktop/io.github.accessory.minus_games_client.metainfo.xml /app/share/metainfo/io.github.accessory.minus_games_client.metainfo.xml"
    ],
    "sources": [
      {
        "type": "git",
        "url": "https://github.com/Accessory/minus_games/",
        "commit": "431870990f7130aaf0043ac19ece48a72156e69b"
      },
      "generated-sources.json"
    ]
  }
}
