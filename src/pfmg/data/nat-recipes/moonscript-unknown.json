{
  "header": {
    "id": "moonscript",
    "version": "unknown",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "moonscript",
    "buildsystem": "simple",
    "build-options": {
      "prepend-path": "/app/automations/DependencyControl/bin",
      "env": {
        "LUA_PATH": "/app/automations/DependencyControl/share/lua/5.1/?.lua;/app/automations/DependencyControl/share/lua/5.1/?/init.lua;./?.lua;./?/init.lua",
        "LUA_CPATH": "/app/automations/DependencyControl/lib/lua/5.1/?.so;./?.so"
      }
    },
    "build-commands": [
      "make LUA=luajit LUAROCKS=luarocks build",
      "luarocks build"
    ],
    "sources": [
      {
        "type": "git",
        "url": "https://github.com/leafo/moonscript",
        "tag": "v0.6.0",
        "commit": "74e1e55cef028f7a1ef5dc80c116cea4cec45545",
        "x-checker-data": {
          "type": "git",
          "tag-pattern": "^v(\\d+\\.\\d+\\.\\d+)$",
          "version-scheme": "semantic"
        }
      }
    ],
    "modules": [
      {
        "name": "luarocks",
        "build-options": {
          "prefix": "/app/automations/DependencyControl"
        },
        "buildsystem": "autotools",
        "config-opts": [
          "--with-lua=/app",
          "--lua-version=5.1",
          "--with-lua-interpreter=luajit"
        ],
        "sources": [
          {
            "type": "git",
            "url": "https://github.com/luarocks/luarocks",
            "tag": "v3.13.0",
            "commit": "3421bedc2ce2b64e79530bb97497531b014899a8",
            "x-checker-data": {
              "type": "git",
              "tag-pattern": "^v(\\d+\\.\\d+\\.\\d+)$",
              "version-scheme": "semantic"
            }
          }
        ]
      },
      {
        "name": "luarocks-alt-getopt_rock",
        "buildsystem": "simple",
        "build-options": {
          "prepend-path": "/app/automations/DependencyControl/bin"
        },
        "build-commands": [
          "luarocks build ./alt-getopt-0.8.0-1.src.rock"
        ],
        "sources": [
          {
            "type": "file",
            "url": "https://luarocks.org/manifests/mpeterv/alt-getopt-0.8.0-1.src.rock",
            "sha512": "501168c6a53094b0d49805ae69bd59722c75155c41d5d71d9a8ad93120fcb8a516b67909702331df838216f817e20c941e26a76de7c643743525e71e9e2dc0b2"
          }
        ]
      },
      {
        "name": "luarocks-luafilesystem",
        "buildsystem": "simple",
        "build-options": {
          "prepend-path": "/app/automations/DependencyControl/bin"
        },
        "build-commands": [
          "luarocks build"
        ],
        "sources": [
          {
            "type": "git",
            "url": "https://github.com/lunarmodules/luafilesystem",
            "tag": "v1_9_0",
            "commit": "a186cca5833691e830ed255e38ace8ff6b870dbf"
          }
        ]
      },
      {
        "name": "luarocks-lpeg_rock",
        "buildsystem": "simple",
        "build-options": {
          "prepend-path": "/app/automations/DependencyControl/bin"
        },
        "build-commands": [
          "luarocks build ./lpeg-1.1.0-2.src.rock"
        ],
        "sources": [
          {
            "type": "file",
            "url": "https://luarocks.org/manifests/gvvaughan/lpeg-1.1.0-2.src.rock",
            "sha512": "e2c9dd2c8bdbb14dcedead7708dcc98c95e5c6a5f90ca0768886dfa16e97936283e6b433ffced1ef3f67f6e8f36a41615153dd570d1089e6b8fc446a59bb2fb1"
          }
        ]
      },
      {
        "name": "luarocks-argparse_rock",
        "buildsystem": "simple",
        "build-options": {
          "prepend-path": "/app/automations/DependencyControl/bin"
        },
        "build-commands": [
          "luarocks build ./argparse-0.7.1-1.src.rock"
        ],
        "sources": [
          {
            "type": "file",
            "url": "https://luarocks.org/manifests/argparse/argparse-0.7.1-1.src.rock",
            "sha512": "0397e8d14baa93f0736baf5c995bc940ae345e309262adac191fae8902d7d275cc882ae556f72b0660d308d0ceaea6dcd41602a56f211a4fbf5fb9b768bccbf7"
          }
        ]
      }
    ]
  }
}
