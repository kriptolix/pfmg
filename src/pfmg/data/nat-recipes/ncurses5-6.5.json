{
  "header": {
    "id": "ncurses5",
    "version": "6.5",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "ncurses5",
    "config-opts": [
      "--with-shared",
      "--with-normal",
      "--without-debug",
      "--without-ada",
      "--enable-widec",
      "--disable-pc-files",
      "--with-cxx-binding",
      "--with-cxx-shared",
      "--with-versioned-syms",
      "--with-abi-version=5"
    ],
    "post-install": [
      "for lib in ncurses ncurses++ form panel menu; do ln -s lib${lib}w.so.5 /app/lib/lib${lib}.so.5; done",
      "ln -s libncurses.so.5 /app/lib/libtinfo.so.5",
      "ln -s libncurses.so.5 /app/lib/libtic.so.5"
    ],
    "cleanup": [
      "/bin",
      "/include",
      "/lib/*.a",
      "/lib/*.so"
    ],
    "sources": [
      {
        "type": "archive",
        "url": "https://ftp.gnu.org/pub/gnu/ncurses/ncurses-6.5.tar.gz",
        "sha256": "136d91bc269a9a5785e5f9e980bc76ab57428f604ce3e5a5a90cebc767971cc6"
      }
    ]
  }
}
