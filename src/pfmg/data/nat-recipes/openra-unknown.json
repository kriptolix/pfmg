{
  "header": {
    "id": "openra",
    "version": "unknown",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "OpenRA",
    "sources": [
      {
        "type": "archive",
        "strip-components": 0,
        "url": "https://github.com/OpenRA/OpenRA/releases/download/release-20250330/OpenRA-release-20250330-source.tar.bz2",
        "sha256": "496a3d0b457dd8d5f53807e740e984278167292882e0ec3566d5add2d3fdf05f",
        "x-checker-data": {
          "type": "json",
          "url": "https://api.github.com/repos/OpenRA/OpenRA/releases",
          "version-query": "[.[].tag_name | select(startswith(\"release-\"))] | sort_by(split(\"-\")[1:])[-1]",
          "url-query": ".[].assets[] | select(.name == \"OpenRA-\" + $version + \"-source.tar.bz2\").browser_download_url"
        }
      },
      {
        "type": "file",
        "path": "nuget.config.xml",
        "dest-filename": "nuget.config"
      },
      "nuget-sources.json",
      {
        "type": "file",
        "path": "IP2LOCATION-LITE-DB1.IPV6.BIN.ZIP"
      },
      {
        "type": "script",
        "commands": [
          "# NOP"
        ],
        "dest-filename": "fetch-geoip.sh"
      },
      {
        "type": "file",
        "path": "openra.metainfo.xml.in"
      }
    ],
    "build-options": {
      "arch": {
        "aarch64": {
          "env": {
            "RUNTIME": "linux-arm64"
          }
        },
        "x86_64": {
          "env": {
            "RUNTIME": "linux-x64"
          }
        }
      }
    },
    "buildsystem": "simple",
    "build-commands": [
      "if git rev-parse 2>/dev/null; then make version; fi",
      "make prefix=/app TARGETPLATFORM=\"${RUNTIME}\" install",
      "make prefix=/app install-linux-shortcuts",
      "# Set version and release date in our custom Metainfo and install it\nset -e\nversion=\"$(cat VERSION)\"\n# Extract release date from release version (e.g. release-20200503)\ndate=\"$(sed -ne 's/^.*-\\([0-9]\\{4\\}\\)\\([0-9]\\{2\\}\\)\\([0-9]\\{2\\}\\)$/\\1-\\2-\\3/p' <<<\"$version\")\"\nif [ -z \"$date\" ]; then\n  # Use date of git commit as fallback (e.g. building a dev version)\n  date=\"$(git log -1 --date=short --format=%cd)\"\nfi\nsed -e \"s/{RELEASE_VERSION}/${version}/g\" -e \"s/{RELEASE_DATE}/${date}/g\" openra.metainfo.xml.in >openra.metainfo.xml\ninstall -Dm0644 -t /app/share/metainfo openra.metainfo.xml\n"
    ]
  }
}
