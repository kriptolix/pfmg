{
  "header": {
    "id": "opera-gx",
    "version": "131.0.5877.36",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "opera-gx",
    "buildsystem": "simple",
    "build-commands": [
      "bsdtar --to-stdout -xf opera-gx.deb 'data.tar*' | bsdtar -xf -",
      "mv usr/lib/x86_64-linux-gnu/opera-gx-stable ${FLATPAK_DEST}/opera-gx",
      "mv ${FLATPAK_DEST}/opera-gx/opera ${FLATPAK_DEST}/opera-gx/opera-gx",
      "install -Dm 644 cobalt.ini ${FLATPAK_DEST}/etc",
      "install -Dm 644 usr/share/metainfo/opera-gx-stable.metainfo.xml ${FLATPAK_DEST}/share/metainfo/opera-gx.metainfo.xml",
      "install -Dm 644 usr/share/applications/opera-gx.desktop ${FLATPAK_DEST}/share/applications/opera-gx.desktop",
      "desktop-file-edit --set-icon=com.opera.opera-gx ${FLATPAK_DEST}/share/applications/opera-gx.desktop",
      "install -Dm 644 usr/share/icons/hicolor/256x256/apps/opera-gx.png ${FLATPAK_DEST}/share/icons/hicolor/256x256/apps/${FLATPAK_ID}.png",
      "install -Dm 755 opera.sh ${FLATPAK_DEST}/bin/opera-gx",
      "install -Dm0644 usr/share/doc/opera-gx-stable/copyright -t $FLATPAK_DEST/share/licenses/$FLATPAK_ID/opera-gx"
    ],
    "sources": [
      {
        "type": "file",
        "dest-filename": "opera-gx.deb",
        "only-arches": [
          "x86_64"
        ],
        "url": "https://get.opera.com/pub/opera_gx/131.0.5877.36/linux/opera-gx-stable_131.0.5877.36_amd64.deb",
        "sha256": "3f09c0decd3eb68ed0481d0b07b1771becaa1072c6ed795440c289ee70f12065",
        "x-checker-data": {
          "is-main-source": true,
          "type": "anitya",
          "project-id": 7242,
          "stable-only": true,
          "url-template": "https://get.geo.opera.com/pub/opera/desktop/$version/linux/opera-gx-stable_${version}_amd64.deb"
        }
      },
      {
        "type": "file",
        "path": "cobalt.ini"
      },
      {
        "type": "file",
        "path": "opera.sh"
      }
    ]
  }
}
