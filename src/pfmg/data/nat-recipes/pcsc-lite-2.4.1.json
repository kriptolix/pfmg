{
  "header": {
    "id": "pcsc-lite",
    "version": "2.4.1",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "pcsc-lite",
    "config-opts": [
      "--disable-libudev",
      "--disable-libsystemd",
      "--disable-polkit",
      "--without-systemdsystemunitdir",
      "--disable-serial",
      "--disable-usb",
      "--disable-documentation"
    ],
    "cleanup": [
      "/include",
      "/lib/pkgconfig"
    ],
    "post-install": [
      "rm /app/sbin/pcscd",
      "rmdir /app/sbin || true"
    ],
    "sources": [
      {
        "type": "archive",
        "url": "https://salsa.debian.org/rousseau/PCSC/-/archive/2.4.1/PCSC-2.4.1.tar.bz2",
        "sha256": "b10104a92b9c066a2d02cc2d8b539cb3a9f720d217799233dbe1dc1234b0aeaa",
        "x-checker-data": {
          "type": "anitya",
          "project-id": 2611,
          "url-template": "https://salsa.debian.org/rousseau/PCSC/-/archive/$version/PCSC-$version.tar.bz2"
        }
      }
    ]
  }
}
