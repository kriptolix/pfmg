{
  "header": {
    "id": "perl-cairo",
    "version": "1.109",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "perl-cairo",
    "buildsystem": "simple",
    "build-commands": [
      "perl Makefile.PL PREFIX=/app LIB=/app/lib",
      "make",
      "make test",
      "make install"
    ],
    "post-install": [
      "find ${FLATPAK_DEST}/lib/ -name \\*.so -exec chmod u+w {} \\;"
    ],
    "sources": [
      {
        "type": "archive",
        "url": "https://cpan.metacpan.org/authors/id/X/XA/XAOC/Cairo-1.109.tar.gz",
        "sha256": "8219736e401c2311da5f515775de43fd87e6384b504da36a192f2b217643077f"
      }
    ]
  }
}
