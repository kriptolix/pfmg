{
  "header": {
    "id": "perl-glib",
    "version": "1.3294",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "perl-glib",
    "buildsystem": "simple",
    "build-commands": [
      "perl Makefile.PL PREFIX=/app LIB=/app/lib",
      "make",
      "make test",
      "make install"
    ],
    "post-install": [
      "find ${FLATPAK_DEST}/lib/ -name \\*.so -exec chmod u+w {} \\;"
    ],
    "sources": [
      {
        "type": "archive",
