{
  "header": {
    "id": "perl-http-date",
    "version": "6.02",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "perl-http-date",
    "buildsystem": "simple",
    "build-commands": [
      "perl Makefile.PL",
      "make install DESTDIR=`pwd`/INST INSTALLSITELIB=/SITELIB",
      "mkdir -p $FLATPAK_DEST/share/perl5/",
      "cp -fr ./INST/SITELIB/* $FLATPAK_DEST/share/perl5/"
    ],
    "sources": [
      {
        "type": "archive",
        "url": "https://cpan.metacpan.org/authors/id/G/GA/GAAS/HTTP-Date-6.02.tar.gz",
