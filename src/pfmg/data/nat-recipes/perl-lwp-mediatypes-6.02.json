{
  "header": {
    "id": "perl-lwp-mediatypes",
    "version": "6.02",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "perl-lwp-mediatypes",
    "buildsystem": "simple",
    "build-commands": [
      "perl Makefile.PL",
      "make install DESTDIR=`pwd`/INST INSTALLSITELIB=/SITELIB",
      "mkdir -p $FLATPAK_DEST/share/perl5/",
      "cp -fr ./INST/SITELIB/* $FLATPAK_DEST/share/perl5/"
    ],
    "sources": [
      {
        "type": "archive",
