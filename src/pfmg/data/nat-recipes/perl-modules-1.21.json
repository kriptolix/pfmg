{
  "header": {
    "id": "perl-modules",
    "version": "1.21",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "perl-modules",
    "buildsystem": "simple",
    "build-commands": [
      "echo 'this is a workaround for a flatpak+perl limitation'",
      "cd Parse-Yapp && perl Makefile.PL && make && make install",
      "cd JSON && perl Makefile.PL && make && make install"
    ],
    "post-install": [
      "chmod -R u+w /app/lib/perl5"
    ],
    "sources": [
      {
