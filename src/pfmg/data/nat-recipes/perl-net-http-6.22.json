{
  "header": {
    "id": "perl-net-http",
    "version": "6.22",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "perl-net-http",
    "buildsystem": "simple",
    "build-commands": [
      "perl Makefile.PL",
      "make install DESTDIR=`pwd`/INST INSTALLSITELIB=/SITELIB",
      "mkdir -p $FLATPAK_DEST/share/perl5/",
      "cp -fr ./INST/SITELIB/* $FLATPAK_DEST/share/perl5/"
    ],
    "sources": [
