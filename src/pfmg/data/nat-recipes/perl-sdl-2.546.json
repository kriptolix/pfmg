{
  "header": {
    "id": "perl-sdl",
    "version": "2.546",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "perl-sdl",
    "no-autogen": true,
    "build-options": {
      "cflags": "-Wno-error=implicit-function-declaration"
    },
    "sources": [
      {
        "type": "archive",
        "url": "https://search.cpan.org/CPAN/authors/id/F/FR/FROGGS/SDL-2.546.tar.gz",
        "sha256": "e08aa73550b3f8d32ced0941c3c629f01c4ba4d480fc269e57f3fa6f8df86631"
      },
      {
        "type": "file",
        "path": "perl-BuildPL-Makefile",
        "dest-filename": "Makefile"
      },
      {
        "type": "patch",
        "path": "perl-sdl-fix-gcc15.patch"
      },
      {
        "type": "patch",
        "path": "perl-sdl-implicit-declaration-fix.patch"
      }
    ],
    "post-install": [
      "find /app/lib/perl5 -type f -exec chmod u+w {} \\;"
    ]
  }
}
