{
  "header": {
    "id": "perl-uri",
    "version": "5.08",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "perl-uri",
    "buildsystem": "simple",
    "build-commands": [
      "perl Makefile.PL",
      "make install DESTDIR=`pwd`/INST INSTALLSITELIB=/SITELIB",
      "mkdir -p $FLATPAK_DEST/share/perl5/",
      "cp -fr ./INST/SITELIB/* $FLATPAK_DEST/share/perl5/"
    ],
    "sources": [
      {
        "type": "archive",
