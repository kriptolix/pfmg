  },
  "module": {
    "name": "perl-xml-parser",
    "buildsystem": "simple",
    "build-commands": [
      "perl Makefile.PL PREFIX=/app LIB=/app/lib",
      "make",
      "make install"
    ],
    "post-install": [
      "find ${FLATPAK_DEST}/lib/ -name \\*.so -exec chmod u+w {} \\;"
    ],
