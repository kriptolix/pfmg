{
  "header": {
    "id": "pinentry",
    "version": "1.3.2",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "pinentry",
    "cleanup": [
      "/include",
      "/share/info",
      "*.a",
      "*.la"
    ],
    "config-opts": [
      "--disable-fallback-curses",
      "--disable-ncurses",
      "--disable-pinentry-curses",
      "--disable-pinentry-emacs",
      "--disable-pinentry-fltk",
      "--disable-pinentry-gtk2",
      "--disable-pinentry-qt5",
      "--disable-pinentry-tqt",
      "--disable-pinentry-tty",
      "--enable-libsecret=no",
      "--enable-pinentry-gnome3",
      "--without-libcap"
    ],
    "sources": [
      {
        "type": "archive",
        "url": "https://www.gnupg.org/ftp/gcrypt/pinentry/pinentry-1.3.2.tar.bz2",
        "sha256": "8e986ed88561b4da6e9efe0c54fa4ca8923035c99264df0b0464497c5fb94e9e",
        "x-checker-data": {
          "type": "anitya",
          "project-id": 3643,
          "stable-only": true,
          "url-template": "https://www.gnupg.org/ftp/gcrypt/pinentry/pinentry-$version.tar.bz2"
        }
      }
    ]
  }
}
