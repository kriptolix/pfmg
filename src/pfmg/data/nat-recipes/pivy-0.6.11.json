{
  "header": {
    "id": "pivy",
    "version": "0.6.11",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "pivy",
    "buildsystem": "cmake-ninja",
    "config-opts": [
      "-DPIVY_USE_QT6=ON",
      "-DCMAKE_POLICY_VERSION_MINIMUM=3.5"
    ],
    "sources": [
      {
        "type": "archive",
        "url": "https://github.com/coin3d/pivy/archive/refs/tags/0.6.11.tar.gz",
        "sha256": "78f79bd7d1ce7e8140ceba4b1220136ea1f14b4403b1e463c59fa892feed961e"
      },
      {
        "type": "shell",
        "commands": [
          "sitepackagesDir=$(python3 -c 'import sysconfig; print(sysconfig.get_paths()[\"platlib\"].replace(\"/usr\",\"/app\"))')\nsed -i \"s|\\${Python_SITEARCH}|$sitepackagesDir|\" {*/,./}CMakeLists.txt\n"
        ]
      }
    ]
  }
}
