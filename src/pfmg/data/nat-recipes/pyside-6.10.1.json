{
  "header": {
    "id": "pyside",
    "version": "6.10.1",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "pyside",
    "buildsystem": "cmake-ninja",
    "builddir": true,
    "build-options": {
      "cflags": "-I/usr/include/python3.13"
    },
    "config-opts": [
      "-DCMAKE_BUILD_TYPE=Release",
      "-DBUILD_TESTS=OFF",
      "-DCMAKE_SKIP_RPATH:BOOL=YES",
      "-DFORCE_LIMITED_API=OFF"
    ],
    "cleanup": [
      "/bin",
      "/lib/plugins/designer",
      "/PySide6"
    ],
    "sources": [
      {
        "type": "archive",
        "url": "https://download.qt.io/official_releases/QtForPython/pyside6/PySide6-6.10.1-src/pyside-setup-everywhere-src-6.10.1.tar.xz",
        "sha256": "fd54f40853d61dfd845dbb40d4f89fbd63df5ed341b3d9a2c77bb5c947a0a838"
      },
      {
        "type": "shell",
        "commands": [
          "cp -R /usr/include/Qt* sources/pyside6/PySide6/"
        ]
      }
    ],
    "post-install": [
      "sed -i 's|${PACKAGE_PREFIX_DIR}/typesystems|/app/share/PySide6/typesystems|g' /app/lib/cmake/PySide6/PySide6Config*.cmake",
      "sed -i 's|${PACKAGE_PREFIX_DIR}/glue|/app/share/PySide6/glue|g' /app/lib/cmake/PySide6/PySide6Config*.cmake"
    ],
    "modules": [
      {
        "name": "shiboken",
        "buildsystem": "cmake-ninja",
        "builddir": true,
        "subdir": "sources/shiboken6",
        "cleanup": [
          "/lib/wheels",
          "/shiboken6/include"
        ],
        "config-opts": [
          "-DBUILD_TESTS=OFF",
          "-DFORCE_LIMITED_API=OFF"
        ],
        "sources": [
          {
            "type": "archive",
            "url": "https://download.qt.io/official_releases/QtForPython/pyside6/PySide6-6.10.1-src/pyside-setup-everywhere-src-6.10.1.tar.xz",
            "sha256": "fd54f40853d61dfd845dbb40d4f89fbd63df5ed341b3d9a2c77bb5c947a0a838"
          }
        ]
      }
    ]
  }
}
