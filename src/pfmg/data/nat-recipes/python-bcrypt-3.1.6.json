{
  "header": {
    "id": "python-bcrypt",
    "version": "3.1.6",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "python-bcrypt",
    "buildsystem": "simple",
    "build-options": {
      "arch": {
        "i386": {
          "env": {
            "MAX_CONCURRENCY": "1"
          }
        },
        "arm": {
          "env": {
            "MAX_CONCURRENCY": "1"
          }
        }
      }
    },
    "ensure-writable": [
      "/lib/python*/site-packages/easy-install.pth",
      "/lib/python*/site-packages/setuptools.pth",
      "/app/lib/python*/site-packages/easy-install.pth",
      "/app/lib/python*/site-packages/setuptools.pth"
    ],
    "build-commands": [
      "python3 setup.py install --prefix=/app --root=/"
    ],
    "sources": [
      {
        "type": "archive",
        "url": "https://github.com/pyca/bcrypt/archive/3.1.6.tar.gz",
        "sha256": "169d3e6edbf8717e8856748b72fb02abe8ce8e0b65d733b1509ae9942e77f2a9"
      }
    ]
  }
}
