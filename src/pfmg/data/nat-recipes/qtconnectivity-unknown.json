{
  "header": {
    "id": "qtconnectivity",
    "version": "unknown",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "qtconnectivity",
    "buildsystem": "simple",
    "cleanup-platform": [
      "/bin",
      "/mkspecs"
    ],
    "sources": [
      {
        "type": "git",
        "url": "https://github.com/qt/qtconnectivity",
        "tag": "v5.15.2",
        "commit": "ca6cc606d9fc0947ea6c27738a1ca8f12f3258ea"
      }
    ],
    "build-commands": [
      "qmake",
      "make -j $FLATPAK_BUILDER_N_JOBS",
      "cp -r -n bin /app",
      "cp -r -n include /app",
      "cp -r -n lib /app",
      "mkdir -p /app/src/bluetooth",
      "cp -r src/bluetooth /app/src/"
    ]
  }
}
