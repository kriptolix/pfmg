{
  "header": {
    "id": "ripgrep",
    "version": "unknown",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "ripgrep",
    "sources": [
      "ripgrep-cargo-sources.yml",
      {
        "type": "git",
        "url": "https://github.com/BurntSushi/ripgrep",
        "tag": "15.1.0",
        "commit": "af60c2de9d85e7f3d81c78601669468cf02dabab",
        "x-checker-data": {
          "type": "git"
        }
      }
    ],
    "build-options": {
      "append-path": "/usr/lib/sdk/rust-stable/bin",
      "env": {
        "CARGO_HOME": "/run/build/ripgrep/cargo"
      }
    },
    "buildsystem": "simple",
    "build-commands": [
      "cargo --frozen build --release",
      "install -Dm755 target/release/rg -t /app/bin"
    ]
  }
}
