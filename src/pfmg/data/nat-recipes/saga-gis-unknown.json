{
  "header": {
    "id": "saga-gis",
    "version": "unknown",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "saga-gis",
    "subdir": "saga-gis",
    "config-opts": [
      "--with-python-prefix=${FLATPAK_DEST}",
      "--with-python-exec-prefix=${FLATPAK_DEST}",
      "--enable-python",
      "--disable-odbc"
    ],
    "sources": [
      {
        "type": "git",
        "url": "git://git.code.sf.net/p/saga-gis/code",
        "tag": "release-7.5.0"
      },
      {
        "type": "patch",
        "path": "patches/saga-gis.patch"
      },
      {
        "type": "script",
        "dest": "saga-gis",
        "dest-filename": "autogen.sh",
        "commands": [
          "AUTOMAKE=\"automake --foreign\" autoreconf -vfi"
        ]
      }
    ],
    "modules": [
      {
        "name": "wxWidgets",
        "cleanup": [
          "/bin",
          "/share/bakefile"
        ],
        "config-opts": [
          "--with-opengl",
          "--with-libjpeg",
          "--with-libtiff",
          "--with-libpng",
          "--with-zlib",
          "--disable-sdltest",
          "--enable-unicode",
          "--enable-display",
          "--enable-propgrid",
          "--disable-webkit",
          "--disable-webview",
          "--disable-webviewwebkit",
          "--with-expat=builtin",
          "--with-libiconv=/usr"
        ],
        "build-options": {
          "cxxflags": "-std=c++0x"
        },
        "sources": [
          {
            "type": "archive",
            "url": "https://github.com/wxWidgets/wxWidgets/releases/download/v3.1.3/wxWidgets-3.1.3.tar.bz2",
            "sha256": "fffc1d34dac54ff7008df327907984b156c50cff5a2f36ee3da6052744ab554a"
          }
        ]
      }
    ]
  }
}
