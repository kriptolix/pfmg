    "buildsystem": "simple",
    "builddir": false,
    "build-commands": [
      "echo '#! /usr/bin/env runhaskell' >Setup.txt",
      "echo '> import Distribution.Simple' >>Setup.txt",
      "echo '> main = defaultMain' >>Setup.txt",
