{
  "header": {
    "id": "sdl-mixer-x",
    "version": "unknown",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "SDL_Mixer_X",
    "buildsystem": "cmake-ninja",
    "builddir": true,
    "sources": [
