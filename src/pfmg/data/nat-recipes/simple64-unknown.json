{
  "header": {
    "id": "simple64",
    "version": "unknown",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "simple64",
    "buildsystem": "simple",
    "build-options": {
      "cflags-override": true,
      "cppflags-override": true,
      "cxxflags-override": true,
      "ldflags-override": true
    },
    "build-commands": [
      "mv /app/discord .",
      "mv /app/vosk .",
      "mv /app/cheats.json .",
      "set -e; NETPLAY_AUTH_CODE=$(cat /app/auth.txt); export NETPLAY_AUTH_CODE; rm /app/auth.txt; ./build.sh",
      "mv simple64 /app",
      "ln -s /app/simple64/simple64-gui /app/bin/simple64-gui"
    ],
    "sources": [
      {
        "type": "git",
        "url": "https://github.com/simple64/simple64.git",
        "tag": "v2024.12.1",
        "commit": "b49e10e5a90aa74ff3d0871d38cf2840ed3effe7",
        "x-checker-data": {
          "is-main-source": true,
          "type": "git",
          "tag-pattern": "^(v[\\d.]+)$"
        }
      }
    ]
  }
}
