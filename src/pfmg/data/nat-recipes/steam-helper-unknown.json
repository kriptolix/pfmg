{
  "header": {
    "id": "steam-helper",
    "version": "unknown",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "steam_helper",
    "subdir": "steam_helper",
    "config-opts": [
      "--nosource-fix",
      "--nolower-include",
      "--nodlls",
      "--nomsvcrt",
      "-L${FLATPAK_LIBDIR}",
      "-L${FLATPAK_LIBDIR_WINE_ELF}",
      "-I${FLATPAK_DEST}/include",
      "-I${FLATPAK_DEST}/include/wine",
      "-I${FLATPAK_DEST}/include/wine/windows",
      "-I../lsteamclient/steamworks_sdk_142",
      "-I../wine/include",
      "-I../openvr/headers",
      "-lsteam_api",
      "-lole32",
      "-ldl",
      "--guiexe",
      "."
    ],
    "build-commands": [
      "winebuild --exe --fake-module -F steam -o steam.exe.fake"
    ],
    "no-make-install": true,
    "post-install": [
      "install -Dm755 steam_helper.exe.so ${FLATPAK_LIBDIR_WINE_ELF}/steam.exe.so",
      "install -Dm755 steam.exe.fake ${FLATPAK_LIBDIR_WINE_PE}/steam.exe"
    ],
    "sources": [
      {
        "type": "git",
        "url": "https://github.com/ValveSoftware/Proton.git",
        "tag": "proton-7.0-6",
        "commit": "c5ad95671cecaf03c4a92500de84b542add585d1",
        "x-checker-data": {
          "type": "json",
          "url": "https://api.github.com/repos/ValveSoftware/Proton/git/refs/tags/proton-",
          "tag-query": "map(select(.ref | match(\"refs/tags/proton-[0-9].*\"; \"\"))) | last | if .object.type==\"commit\" then . else error(\"not a commit\") end | .ref | sub(\"^refs/tags/\"; \"\")",
          "version-query": "$tag | sub(\"^proton-\"; \"\")",
          "commit-query": "map(select(.ref | match(\"refs/tags/proton-[0-9].*\"; \"\"))) | last | .object.sha",
          "timestamp-data-url": "map(select(.ref | match(\"refs/tags/proton-[0-9].*\"; \"\"))) | last | .object.url",
          "timestamp-query": ".committer.date",
          "is-main-source": true,
          "source-id": "proton-git-0"
        }
      },
      {
        "type": "shell",
        "dest": "wine",
        "commands": [
          "tools/make_requests",
          "dlls/winevulkan/make_vulkan --xml vk.xml"
        ]
      },
      {
        "type": "file",
        "path": "winemaker-configure.sh",
        "dest": "steam_helper",
        "dest-filename": "configure"
      }
    ]
  }
}
