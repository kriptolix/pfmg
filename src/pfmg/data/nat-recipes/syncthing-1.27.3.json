{
  "header": {
    "id": "syncthing",
    "version": "1.27.3",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "syncthing",
    "disabled": false,
    "buildsystem": "simple",
    "build-options": {
      "env": {
        "GOBIN": "/app/bin"
      }
    },
    "build-commands": [
      ". /usr/lib/sdk/golang/enable.sh\nexport GOPATH=$PWD/go\ngo version\n# go mod vendor\n#go build -mod=vendor\n#go mod download -json > download.json\nenv GOFLAGS=-mod=vendor go run build.go -no-upgrade build\n",
      "install -Dm755 -t /app/bin syncthing",
      "syncthing -version"
    ],
    "sources": [
      "go-sources.json",
      {
        "type": "archive",
        "url": "https://github.com/syncthing/syncthing/releases/download/v1.27.3/syncthing-source-v1.27.3.tar.gz",
        "sha256": "3fe25b863bb3a0f74bc95a7afa71bdaa2a79971542962236be5d85f469aa897d",
        "x-checker-data": {
          "type": "anitya",
          "project-id": 11814,
          "url-template": "https://github.com/syncthing/syncthing/releases/download/v$version/syncthing-source-v$version.tar.gz",
          "versions": {
            "<": 2
          }
        }
      }
    ]
  }
}
