{
  "header": {
    "id": "vscode-go",
    "version": "unknown",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "build-commands": [
      "GOPATH=$PWD go build -o /app/local/bin/gocode-gomod github.com/stamblerre/gocode",
      "GOPATH=$PWD go build -o /app/local/bin/godef-gomod github.com/ianthehat/godef",
      "GOPATH=$PWD go install github.com/acroca/go-symbols",
      "GOPATH=$PWD go install github.com/alecthomas/gometalinter",
      "GOPATH=$PWD go install github.com/cweill/gotests/...",
      "GOPATH=$PWD go install github.com/davidrjenni/reftools/cmd/fillstruct",
      "GOPATH=$PWD go install github.com/derekparker/delve/cmd/dlv",
      "GOPATH=$PWD go install github.com/fatih/gomodifytags",
      "GOPATH=$PWD go install github.com/golangci/golangci-lint/cmd/golangci-lint",
      "GOPATH=$PWD go install github.com/haya14busa/goplay/cmd/goplay",
      "GOPATH=$PWD go install github.com/josharian/impl",
      "GOPATH=$PWD go install github.com/mdempsky/gocode",
      "GOPATH=$PWD go install github.com/mgechev/revive",
      "GOPATH=$PWD go install github.com/ramya-rao-a/go-outline",
      "GOPATH=$PWD go install github.com/rogpeppe/godef",
      "GOPATH=$PWD go install github.com/sourcegraph/go-langserver",
      "GOPATH=$PWD go install github.com/sqs/goreturns",
      "GOPATH=$PWD go install github.com/tylerb/gotype-live",
      "GOPATH=$PWD go install github.com/uudashr/gopkgs/cmd/gopkgs",
      "GOPATH=$PWD go install github.com/zmb3/gogetdoc",
      "GOPATH=$PWD go install golang.org/x/lint/golint",
      "GOPATH=$PWD go install golang.org/x/tools/cmd/goimports",
      "GOPATH=$PWD go install golang.org/x/tools/cmd/gorename",
      "GOPATH=$PWD go install golang.org/x/tools/cmd/guru",
      "GOPATH=$PWD go install honnef.co/go/tools/...",
      "GOPATH=$PWD go install winterdrache.de/goformat/goformat",
      "mv bin/* /app/local/bin"
    ],
    "build-options": {
      "append-path": "/usr/lib/sdk/golang/bin",
      "env": {
        "GOROOT": "/usr/lib/sdk/golang"
      }
    },
    "buildsystem": "simple",
    "name": "vscode-go",
    "only-arches": [
      "x86_64"
    ],
