{
  "header": {
    "id": "wasabiwallet",
    "version": "2.0.7.1",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "wasabiwallet",
    "buildsystem": "simple",
    "build-commands": [
      "gpg --import publickey.gpg; gpg --verify wasabi.deb.asc wasabi.deb",
      "ar x wasabi.deb",
      "tar -xf data.tar.xz",
      "for size in 16 24 32 48 256; do [[ -e \"usr/share/icons/hicolor/${size}x${size}/apps/wassabee.png\" ]] && install -Dm644 \"usr/share/icons/hicolor/${size}x${size}/apps/wassabee.png\" \"/app/share/icons/hicolor/${size}x${size}/apps/${FLATPAK_ID}.png\"; done",
      "cp -r usr/local/bin/wasabiwallet /app/wasabiwallet"
    ],
    "sources": [
      {
        "type": "file",
        "url": "https://github.com/zkSNACKs/WalletWasabi/releases/download/v2.0.7.1/Wasabi-2.0.7.1.deb",
