{
  "header": {
    "id": "webkitgtk",
    "version": "2.52.3",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "webkitgtk",
    "buildsystem": "simple",
    "build-commands": [
      "mkdir -p /app/lib/webkitgtk-6.0/injected-bundle /app/libexec/webkitgtk-6.0",
      "install -m755 libwebkitgtk-6.0.so.*.*.* /app/lib/",
      "install -m755 libjavascriptcoregtk-6.0.so.*.*.* /app/lib/",
      "ln -sf $(basename libwebkitgtk-6.0.so.*.*.*) /app/lib/libwebkitgtk-6.0.so.4",
      "ln -sf libwebkitgtk-6.0.so.4 /app/lib/libwebkitgtk-6.0.so",
      "ln -sf $(basename libjavascriptcoregtk-6.0.so.*.*.*) /app/lib/libjavascriptcoregtk-6.0.so.1",
      "ln -sf libjavascriptcoregtk-6.0.so.1 /app/lib/libjavascriptcoregtk-6.0.so",
      "install -m755 webkitgtk-6.0/injected-bundle/libwebkitgtkinjectedbundle.so /app/lib/webkitgtk-6.0/injected-bundle/",
      "install -m755 webkitgtk-6.0/WebKitWebProcess /app/libexec/webkitgtk-6.0/",
      "install -m755 webkitgtk-6.0/WebKitNetworkProcess /app/libexec/webkitgtk-6.0/",
      "install -m755 webkitgtk-6.0/WebKitGPUProcess /app/libexec/webkitgtk-6.0/",
      "install -m755 webkitgtk-6.0/jsc /app/libexec/webkitgtk-6.0/"
    ],
    "sources": [
      {
        "type": "archive",
        "url": "https://github.com/tobagin/karere/releases/download/webkitgtk-2.52.3-gnome50/webkitgtk-x86_64.tar.gz",
        "sha256": "c5d5f6ceb38245f7ab26439def38daa7fe313d7c9926631a444d4db85f8f436d",
        "only-arches": [
          "x86_64"
        ]
      },
      {
        "type": "archive",
        "url": "https://github.com/tobagin/karere/releases/download/webkitgtk-2.52.3-gnome50/webkitgtk-aarch64.tar.gz",
        "sha256": "243f3121ee095d2af6e960700f59dab4df1e29415e75b3e30d73c8c8db8f0232",
        "only-arches": [
          "aarch64"
        ]
      }
    ]
  }
}
