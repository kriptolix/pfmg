{
  "header": {
    "id": "wolfssl",
    "version": "unknown",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "wolfssl",
    "buildsystem": "autotools",
    "config-opts": [
      "--enable-shared",
      "--disable-opensslall",
      "--disable-opensslextra",
      "--enable-aescbc-length-checks",
      "--enable-curve25519",
      "--enable-ed25519",
      "--enable-ed25519-stream",
      "--enable-oldtls",
      "--enable-base64encode",
      "--enable-tlsx",
      "--enable-scrypt",
      "--disable-examples",
      "--enable-crl",
      "--enable-jni",
      "--enable-sessioncerts"
    ],
    "sources": [
      {
        "type": "git",
        "url": "https://github.com/wolfSSL/wolfssl.git",
        "tag": "v5.8.4-stable",
        "commit": "59f4fa568615396fbf381b073b220d1e8d61e4c2"
      }
    ]
  }
}
