{
  "header": {
    "id": "xxhash",
    "version": "unknown",
    "type": "native",
    "build_requires": []
  },
  "module": {
    "name": "xxHash",
    "buildsystem": "simple",
    "build-commands": [
      "make PREFIX=${FLATPAK_DEST} -j $FLATPAK_BUILDER_N_JOBS",
      "make PREFIX=${FLATPAK_DEST} install"
