        "tag": "v0.8.2",
        "x-checker-data": {
          "type": "json",
          "url": "https://api.github.com/repos/Cyan4973/xxHash/releases/latest",
          "tag-query": ".tag_name",
          "version-query": "$tag | sub(\"^jq-\"; \"\")",
          "timestamp-query": ".published_at"
        }
      }
    ]
  }
