{
  "header": {
    "id": "git-cola",
    "version": "unknown",
    "type": "python",
    "build_requires": []
  },
  "module": {
    "name": "git-cola",
    "buildsystem": "simple",
    "build-commands": [
      "python3 -m build --wheel --no-isolation",
      "pip3 install --prefix=${FLATPAK_DEST} dist/*.whl",
      "make prefix=${FLATPAK_DEST} install-desktop-files install-icons install-htmldocs install-metainfo"
    ],
    "sources": [
      {
        "type": "git",
        "url": "https://github.com/git-cola/git-cola.git",
        "tag": "v4.18.2",
        "commit": "9e6ae4655f54b32f8efb0d02992c6fad60d2e7f6",
        "x-checker-data": {
          "type": "git",
          "tag-pattern": "^v([\\d.]+)$"
        }
      }
    ]
  }
}
