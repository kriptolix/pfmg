{
  "header": {
    "id": "poezio",
    "version": "0.17",
    "type": "python",
    "build_requires": []
  },
  "module": {
    "name": "poezio",
    "buildsystem": "simple",
    "build-commands": [
      "sed -i '/^Exec=/s,=.*,=/app/bin/poezio,' data/io.poez.Poezio.desktop",
      "sed -i '/^plugins_autoload =/s,=.*,= omemo,' data/default_config.cfg",
      "sed -i /component/s/console-application/desktop/ data/io.poez.Poezio.appdata.xml",
      "pip3 install --prefix=/app --no-build-isolation .",
      "install -Dm644 data/poezio_logo.svg /app/share/icons/hicolor/scalable/apps/io.poez.Poezio.svg"
    ],
    "sources": [
      {
        "type": "archive",
        "url": "https://codeberg.org/poezio/poezio/archive/v0.17.tar.gz",
        "sha256": "fa690ad8158c27839cb881c0b6163e42d2ba5643ba23751c7edf55935e17fa03"
      },
      {
        "type": "patch",
        "path": "0001-appdata-fix-a-bunch-of-stuff.patch"
      },
      {
        "type": "patch",
        "path": "0002-appdata-add-missing-release-info.patch"
      }
    ]
  }
}
