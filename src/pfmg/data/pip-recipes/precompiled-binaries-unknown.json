{
  "header": {
    "id": "precompiled-binaries",
    "version": "unknown",
    "type": "python",
    "build_requires": []
  },
  "module": {
    "name": "precompiled-binaries",
    "only-arches": [
      "x86_64"
    ],
    "buildsystem": "simple",
    "build-options": {
      "env": {
        "PYTHONPATH": "/app/extensions/amd/lib/python3.12/site-packages:/app/lib/python3.12/site-packages"
      }
    },
    "cleanup": [
      "/bin"
    ],
    "build-commands": [
      "pip3 install --verbose --exists-action=i --no-index --prefix=${FLATPAK_DEST} --no-build-isolation *.whl",
      "install -Dm644 *.so* ${FLATPAK_DEST}/lib/",
      "set -e\ncd ${FLATPAK_DEST}/lib\nln -s libctranslate2.so.4.3.1 libctranslate2.so.4\nln -s libctranslate2.so.4.3.1 libctranslate2.so\nln -s libwhisper-hipblas.so.1.7.1 libwhisper-hipblas.so.1\nln -s libwhisper-hipblas.so.1.7.1 libwhisper-hipblas.so\n"
    ],
    "sources": [
      {
        "type": "archive",
        "strip-components": 0,
        "url": "https://github.com/mkiol/dsnote/releases/download/b4.8.0-4/flatpak_binaries_amd_1_4.tar.xz",
        "sha256": "613052dd941962ade839214da8a894e81fbb748686964a491d4b4fd2de7547c6"
      }
    ]
  }
}
