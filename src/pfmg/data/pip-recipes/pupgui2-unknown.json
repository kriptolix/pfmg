{
  "header": {
    "id": "pupgui2",
    "version": "unknown",
    "type": "python",
    "build_requires": []
  },
  "module": {
    "name": "pupgui2",
    "buildsystem": "simple",
    "build-commands": [
      "mkdir -p /app/share",
      "cp -r share /app/",
      "sed -i \"s/BUILD_INFO = .*/BUILD_INFO = 'DavidoTek Flathub build'/\" pupgui2/constants.py",
      "pip3 install --verbose --no-index --prefix=${FLATPAK_DEST} --no-build-isolation --no-deps ."
    ],
    "sources": [
      {
        "type": "git",
        "url": "https://github.com/DavidoTek/ProtonUp-Qt",
        "tag": "v2.15.0",
        "commit": "e472d8c89c07fcdc5f04292a838f4b636fbb7a84",
        "x-checker-data": {
          "type": "git",
          "tag-pattern": "^v([\\d.]+)$",
          "is-important": true
        }
      }
    ]
  }
}
