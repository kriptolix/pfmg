{
  "header": {
    "id": "python-pypillowfight",
    "version": "unknown",
    "type": "python",
    "build_requires": []
  },
  "module": {
    "name": "python-pypillowfight",
    "ensure-writable": [
      "/lib/python*/site-packages/easy-install.pth",
      "/lib/python*/site-packages/setuptools.pth"
