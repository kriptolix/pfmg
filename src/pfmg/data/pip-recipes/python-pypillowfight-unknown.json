      "make version",
      "pip3 install --disable-pip-version-check --prefix=/app --no-deps --no-build-isolation ."
    ],
    "sources": [
      {
        "type": "git",
        "url": "https://gitlab.gnome.org/World/OpenPaperwork/libpillowfight.git",
        "tag": "0.3.1",
        "commit": "254018aad15710af6e9bdc5eb61aaa7dbac6f747",
        "disable-shallow-clone": true
      }
    ]
  }
}
