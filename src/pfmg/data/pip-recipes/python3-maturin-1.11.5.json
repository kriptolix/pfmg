{
  "header": {
    "id": "python3-maturin",
    "version": "1.11.5",
    "type": "python",
    "build_requires": []
  },
  "module": {
    "name": "python3-maturin",
    "buildsystem": "simple",
    "build-commands": [
      "pip3 install --verbose --exists-action=i --no-index --find-links=\"file://${PWD}\" --prefix=${FLATPAK_DEST} \"maturin\" --no-build-isolation"
    ],
    "sources": [
      {
        "type": "file",
        "url": "https://files.pythonhosted.org/packages/a4/84/bfed8cc10e2d8b6656cf0f0ca6609218e6fcb45a62929f5094e1063570f7/maturin-1.11.5.tar.gz",
        "sha256": "7579cf47640fb9595a19fe83a742cbf63203f0343055c349c1cab39045a30c29"
      },
      "cargo-dependencies/maturin.json"
    ],
    "build-options": {
      "append-path": "/usr/lib/sdk/rust-stable/bin",
      "env": {
        "CARGO_HOME": "/run/build/python3-maturin/cargo",
        "CARGO_NET_OFFLINE": "true",
        "RUST_BACKTRACE": "1"
      }
    }
  }
}
