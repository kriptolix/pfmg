{
  "header": {
    "id": "python3-rpds-py",
    "version": "0.30.0",
    "type": "python",
    "build_requires": []
  },
  "module": {
    "name": "python3-rpds-py",
    "buildsystem": "simple",
    "build-commands": [
      "pip3 install --verbose --exists-action=i --no-index --find-links=\"file://${PWD}\" --prefix=${FLATPAK_DEST} \"rpds-py\" --no-build-isolation"
